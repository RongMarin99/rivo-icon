{
  "name": "@rivo-icons/svelte",
  "version": "0.0.4",
  "description": "Free, open-source SVG icons for Svelte and SvelteKit — currentColor, TypeScript, tree-shakeable",
  "keywords": [
    "icons",
    "svg",
    "icon-library",
    "svelte",
    "sveltekit",
    "svelte-icons",
    "svelte-components",
    "currentColor",
    "typescript",
    "tree-shakeable",
    "ui"
  ],
  "homepage": "https://rivo-icon.rongmarin.info",
  "repository": {
    "type": "git",
    "url": "https://github.com/RongMarin99/rivo-icon.git",
    "directory": "packages/svelte"
  },
  "license": "MIT",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "svelte": "src/index.js",
  "exports": {
    ".": {
      "svelte": "./src/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "svelte-package -i src",
    "dev": "svelte-package -i src --watch",
    "typecheck": "svelte-check",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "svelte": ">=4.0.0"
  },
  "dependencies": {
    "@rivo-icons/shared": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.0.0",
    "svelte": "^4.0.0",
    "svelte-check": "^3.0.0",
    "typescript": "^5.5.0"
  }
}
