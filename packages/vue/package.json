{
  "name": "@rivo-icons/vue",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external vue",
    "dev": "tsup src/index.ts --format esm --dts --external vue --watch",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "dependencies": {
    "@rivo-icons/shared": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
