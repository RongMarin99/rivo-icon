{
  "name": "@rivo-icons/vue",
  "version": "0.0.4",
  "description": "Free, open-source SVG icons for Vue 3 — currentColor, TypeScript, tree-shakeable",
  "keywords": [
    "icons",
    "svg",
    "icon-library",
    "vue",
    "vue3",
    "vue-icons",
    "vue-components",
    "composition-api",
    "currentColor",
    "typescript",
    "tree-shakeable",
    "ui"
  ],
  "homepage": "https://rivo-icon.rongmarin.info",
  "repository": {
    "type": "git",
    "url": "https://github.com/RongMarin99/rivo-icon.git",
    "directory": "packages/vue"
  },
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external vue",
    "dev": "tsup src/index.ts --format esm --dts --external vue --watch",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "dependencies": {
    "@rivo-icons/shared": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
