{
  "name": "@rivo-icons/solid",
  "version": "0.0.3",
  "description": "Free, open-source SVG icons for Solid.js — currentColor, TypeScript, tree-shakeable",
  "keywords": [
    "icons",
    "svg",
    "icon-library",
    "solid",
    "solid-js",
    "solidjs",
    "solid-icons",
    "currentColor",
    "typescript",
    "tree-shakeable",
    "ui"
  ],
  "homepage": "https://rivo-icon.rongmarin.info",
  "repository": {
    "type": "git",
    "url": "https://github.com/RongMarin99/rivo-icon.git",
    "directory": "packages/solid"
  },
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external solid-js",
    "dev": "tsup src/index.ts --format esm --dts --external solid-js --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "solid-js": ">=1.0.0"
  },
  "dependencies": {
    "@rivo-icons/shared": "workspace:*"
  },
  "devDependencies": {
    "solid-js": "^1.8.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
