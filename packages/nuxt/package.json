{
  "name": "@rivo-icons/nuxt",
  "version": "0.0.3",
  "description": "Nuxt module for Rivo Icons — auto-imported SVG icon components, currentColor, TypeScript",
  "keywords": [
    "icons",
    "svg",
    "icon-library",
    "nuxt",
    "nuxt3",
    "nuxt-module",
    "nuxt-icons",
    "auto-import",
    "vue",
    "currentColor",
    "typescript",
    "ssr"
  ],
  "homepage": "https://rivo-icon.rongmarin.info",
  "repository": {
    "type": "git",
    "url": "https://github.com/RongMarin99/rivo-icon.git",
    "directory": "packages/nuxt"
  },
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/module.mjs",
      "types": "./dist/types.d.ts"
    }
  },
  "scripts": {
    "build": "nuxt-module-build build",
    "dev": "nuxt-module-build build --stub",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nuxt/kit": "^3.13.0",
    "@rivo-icons/vue": "workspace:*"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^0.8.0",
    "typescript": "^5.5.0"
  }
}
