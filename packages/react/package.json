{
  "name": "@rivo-icons/react",
  "version": "0.0.4",
  "description": "Free, open-source SVG icons for React — currentColor, TypeScript, tree-shakeable",
  "keywords": [
    "icons",
    "svg",
    "icon-library",
    "react",
    "react-icons",
    "react-components",
    "currentColor",
    "typescript",
    "tree-shakeable",
    "ui",
    "design-system"
  ],
  "homepage": "https://rivo-icon.rongmarin.info",
  "repository": {
    "type": "git",
    "url": "https://github.com/RongMarin99/rivo-icon.git",
    "directory": "packages/react"
  },
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external react",
    "dev": "tsup src/index.ts --format esm --dts --external react --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@rivo-icons/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
